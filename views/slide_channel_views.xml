<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_slide_channel_form_inherit_invite_by_tag" model="ir.ui.view">
        <field name="name">slide.channel.form.invite.by.tag</field>
        <field name="model">slide.channel</field>
        <field name="inherit_id" ref="website_slides.view_slide_channel_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_invite_by_tag_wizard"
                        type="object"
                        string="Invite by Tag"
                        class="oe_highlight"
                        groups="website_slides.group_website_slides_manager"/>
            </xpath>
        </field>
    </record>
</odoo>