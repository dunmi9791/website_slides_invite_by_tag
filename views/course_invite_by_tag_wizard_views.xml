<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_course_invite_by_tag_wizard_form" model="ir.ui.view">
        <field name="name">course.invite.by.tag.wizard.form</field>
        <field name="model">course.invite.by.tag.wizard</field>
        <field name="arch" type="xml">
            <form string="Invite Participants by Tag">
                <sheet>
                    <group>
                        <group string="Audience Selection">
                            <field name="course_id" readonly="1"/>
                            <field name="partner_tag_ids" widget="many2many_tags"/>
                            <field name="employee_tag_ids" widget="many2many_tags"/>
                            <field name="tag_match"/>
                        </group>
                        <group string="Options">
                            <field name="only_with_email"/>
                            <field name="exclude_already_enrolled"/>
                            <field name="auto_enroll"/>
                            <field name="send_email"/>
                        </group>
                    </group>

                    <group string="Preview">
                        <group>
                            <field name="matched_employee_count" readonly="1"/>
                            <field name="unresolved_employee_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="matched_count" readonly="1"/>
                            <field name="enrolled_count" readonly="1"/>
                            <field name="email_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Matched Employees">
                            <field name="employee_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                        </page>
                        <page string="Matched Participants">
                            <field name="partner_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_invite_participants"
                            type="object"
                            string="Run Invite"
                            class="oe_highlight"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>