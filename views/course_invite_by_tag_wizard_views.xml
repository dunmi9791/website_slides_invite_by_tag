<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_course_invite_by_tag_wizard_form" model="ir.ui.view">
        <field name="name">course.invite.by.tag.wizard.form</field>
        <field name="model">course.invite.by.tag.wizard</field>
        <field name="arch" type="xml">
            <form string="Invite Participants by Tag">
                <sheet>
                    <group>
                        <group>
                            <field name="course_id" readonly="1"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'no_create_edit': False}"/>
                            <field name="tag_match"/>
                        </group>
                        <group>
                            <field name="only_with_email"/>
                            <field name="exclude_already_enrolled"/>
                            <field name="auto_enroll"/>
                            <field name="send_email"/>
                        </group>
                    </group>

                    <group string="Preview">
                        <group>
                            <field name="matched_count" readonly="1"/>
                            <field name="enrolled_count" readonly="1"/>
                            <field name="email_count" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <field name="partner_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_invite_participants"
                            type="object"
                            string="Run Invite"
                            class="btn btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
